<script>

function register(){

let user={

name:name.value,

email:email.value,

password:password.value

};

localStorage.setItem("daviesUser",JSON.stringify(user));

alert("Registration Successful!");

}

function login(){

let user=JSON.parse(localStorage.getItem("daviesUser"));

if(user==null){

alert("Register First");

return;

}

if(loginEmail.value==user.email && loginPassword.value==user.password){

loginPage.style.display="none";

homePage.style.display="block";

welcome.innerHTML="Welcome, "+user.name+" 👋";

}

else{

alert("Wrong Email or Password");

}

}

function logout(){

location.reload();

}

</script>

